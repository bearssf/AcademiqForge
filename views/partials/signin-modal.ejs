<% if (!user) { %>
<div class="modal-backdrop" id="signin-modal" role="dialog" aria-modal="true" aria-labelledby="signin-title">
  <div class="modal">
    <button type="button" class="modal-close" id="close-signin" aria-label="<%= t('client.common.close') %>">&times;</button>
    <h2 id="signin-title" style="margin:0 0 1rem;"><%= t('auth.signInTitle') %></h2>
    <% if (typeof resetSuccess !== 'undefined' && resetSuccess) { %>
      <p class="success-msg"><%= t('auth.resetSuccess') %></p>
    <% } %>
    <% if (typeof error !== 'undefined' && error === 'missing') { %>
      <p class="error-msg"><%= t('auth.errorMissing') %></p>
    <% } else if (typeof error !== 'undefined' && error === 'invalid') { %>
      <p class="error-msg"><%= t('auth.errorInvalid') %></p>
    <% } else if (typeof error !== 'undefined' && error === 'server') { %>
      <p class="error-msg"><%= t('auth.errorServer') %></p>
    <% } %>
    <form action="/login" method="post">
      <input type="hidden" name="returnTo" value="<%= typeof returnTo !== 'undefined' ? returnTo : '/' %>" />
      <div class="field"><label for="signin-email"><%= t('auth.email') %></label><input type="email" id="signin-email" name="email" required autocomplete="email" /></div>
      <div class="field"><label for="signin-password"><%= t('auth.password') %></label><input type="password" id="signin-password" name="password" required autocomplete="current-password" /></div>
      <div class="modal-actions">
        <button type="submit" class="btn btn-blue"><%= t('auth.signInSubmit') %></button>
        <a href="/register" class="create-link"><%= t('auth.createAccount') %></a>
      </div>
      <p class="modal-forgot"><a href="/forgot-password"><%= t('auth.forgotPassword') %></a></p>
    </form>
  </div>
</div>
<% } %>

<script>
  (function () {
    var modal = document.getElementById('signin-modal');
    var openBtn = document.getElementById('open-signin');
    var closeBtn = document.getElementById('close-signin');
    if (!modal) return;
    function openModal() { modal.classList.add('is-open'); var first = modal.querySelector('input[type="email"]'); if (first) setTimeout(function () { first.focus(); }, 50); }
    function closeModal() { modal.classList.remove('is-open'); }
    if (openBtn) openBtn.addEventListener('click', openModal);
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal(); });
    <% if ((typeof error !== 'undefined' && error && !user) || (typeof openSignin !== 'undefined' && openSignin) || (typeof resetSuccess !== 'undefined' && resetSuccess)) { %>openModal();<% } %>
  })();
</script>
