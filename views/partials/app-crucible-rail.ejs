<% var hint = typeof insightHint !== 'undefined' ? insightHint : 'Insights and feedback will appear here as you work in this workspace.'; %>
<aside class="app-insight app-crucible-rail" aria-label="Insights and related sources">
  <div class="app-crucible-rail__stack">
    <div class="app-crucible-rail__pane app-crucible-rail__pane--insight">
      <div class="insight-h">Insight / feedback</div>
      <div class="app-insight-card"><%= hint %></div>
      <div class="app-insight-card" style="opacity:.85">Next best actions and AI suggestions will surface here.</div>
    </div>
    <div class="app-crucible-rail__pane app-crucible-rail__pane--related">
      <div class="crucible-related-rail-top">
        <div class="insight-h insight-h--related">Potential Related Sources</div>
        <button type="button" class="crucible-btn-secondary crucible-related-fetch" id="crucible-related-fetch">Get suggestions</button>
      </div>
      <div id="crucible-related-rail-mount" class="app-crucible-rail__scroll crucible-related-rail-mount"></div>
    </div>
  </div>
</aside>
