<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('product.title') %> – AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/academiq.css" />
  <%- include('partials/i18n-bootstrap') %>
</head>
<body>
  <%
    const featureKeys = ['anvil', 'archive', 'lattice'];
    const navMock = [
      t('product.mockNavDashboard'),
      t('product.mockNavAnvil'),
      t('product.mockNavArchive'),
      t('product.mockNavLattice'),
    ];
  %>
  <div class="shell">
    <%- include('partials/topnav', { user: user, navActive: navActive || 'product' }) %>

    <section class="section product" id="product" style="position:relative">
      <form class="home-lang-form" method="get" action="/locale/set" aria-label="<%= t('home.language') %>" style="position:absolute;top:0;right:0;z-index:2;display:flex;align-items:center;gap:0.5rem;font-size:0.85rem;color:rgba(255,255,255,0.75)">
        <input type="hidden" name="returnTo" value="/product" />
        <label for="product-locale-select" class="home-lang-label"><%= t('home.language') %></label>
        <select id="product-locale-select" name="code" onchange="this.form.submit()" style="max-width:11rem;padding:0.25rem 0.4rem;border-radius:6px;background:rgba(0,0,0,0.35);color:#fff;border:1px solid rgba(255,255,255,0.25)">
          <% (typeof localeOptions !== 'undefined' ? localeOptions : []).forEach(function (opt) { %>
            <option value="<%= opt.id %>" <%= locale === opt.id ? 'selected' : '' %>><%= opt.label %></option>
          <% }); %>
        </select>
      </form>
      <div>
        <div class="eyebrow"><%= t('product.eyebrow') %></div>
        <h2><%= t('product.headline') %></h2>
        <p class="sub"><%= t('product.sub') %></p>
      </div>
      <div class="product-panel">
        <div class="triple">
          <div class="box">
            <div class="u"><%= t('product.mockNavigation') %></div>
            <div class="nav-list">
              <% navMock.forEach(function (item, index) { %>
                <div class="<%= index === 1 ? 'active' : '' %>"><%= item %></div>
              <% }) %>
            </div>
          </div>
          <div class="box">
            <div class="row">
              <div><div class="u"><%= t('product.mockWorkspace') %></div><div class="workspace-title"><%= t('product.mockMethodology') %></div></div>
              <div style="font-size:.84rem;color:rgba(255,255,255,.47)"><%= t('product.mockWordCount') %></div>
            </div>
            <div class="copy" style="margin-top:.7rem">
              <p><%= t('product.mockDemoP1') %></p>
              <p><%= t('product.mockDemoP2') %></p>
              <div class="hint"><%= t('product.mockHint') %></div>
            </div>
          </div>
          <div class="box">
            <div class="u"><%= t('product.mockInsights') %></div>
            <div class="ins">
              <% for (let i = 0; i < 3; i++) { %>
                <div class="ins-item"><%= t('product.insights.' + i) %></div>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="workflow" id="workflow">
      <div class="workflow-top">
        <div><div class="eyebrow"><%= t('product.workflowEyebrow') %></div><h2><%= t('product.workflowHeadline') %></h2></div>
        <p class="sub"><%= t('product.workflowSub') %></p>
      </div>
      <div class="steps">
        <% for (let i = 0; i < 4; i++) { %>
          <div class="step"><div class="n">0<%= i + 1 %></div><div class="t"><%= t('product.steps.' + i) %></div></div>
        <% } %>
      </div>
    </section>

    <section class="section" id="features">
      <div style="max-width:820px">
        <div class="eyebrow"><%= t('product.featuresEyebrow') %></div>
        <h2><%= t('product.featuresHeadline') %></h2>
      </div>
      <div class="feature-grid" style="margin-top:1.4rem">
        <% featureKeys.forEach(function (key) { %>
          <article class="card">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem;">
              <div><h3 style="font-size:2rem"><%= t('product.features.' + key + '.name') %></h3><p><%= t('product.features.' + key + '.desc') %></p></div>
              <div class="ico" style="margin-bottom:0"></div>
            </div>
          </article>
        <% }); %>
      </div>
    </section>

    <section class="cta" id="cta">
      <div class="cta-glow"></div>
      <div class="cta-inner">
        <div class="eyebrow"><%= t('product.ctaEyebrow') %></div>
        <h2><%= t('product.ctaHeadline') %></h2>
        <p class="sub"><%= t('product.ctaSub') %></p>
        <div class="hero-actions" style="justify-content:center; margin-top:1.5rem;">
          <button type="button" class="btn btn-blue"><%= t('product.startForging') %></button>
          <button type="button" class="btn btn-outline"><%= t('product.scheduleDemo') %></button>
        </div>
      </div>
    </section>
  </div>

  <%- include('partials/signin-modal', { user: user, error: error, returnTo: typeof returnTo !== 'undefined' ? returnTo : '/product', openSignin: typeof openSignin !== 'undefined' && openSignin, resetSuccess: typeof resetSuccess !== 'undefined' && resetSuccess }) %>
</body>
</html>
