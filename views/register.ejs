<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create account – AcademiqForge</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0a;
      --card: #121212;
      --border: rgba(255, 255, 255, 0.08);
      --text: #f5f5f5;
      --muted: #9ca3af;
      --primary: #2b82f6;
      --primary-hover: #4b93f7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse 70% 50% at 20% 20%, rgba(43, 130, 246, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse 50% 40% at 85% 75%, rgba(43, 130, 246, 0.06) 0%, transparent 45%);
      color: var(--text);
      font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 15px;
      line-height: 1.5;
      padding: 0 1.25rem 3rem;
    }
    a { color: inherit; }

    .shell {
      max-width: 520px;
      margin: 0 auto;
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 0 1.5rem;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      text-decoration: none;
    }
    .brand-mark {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #141414;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brand-mark span {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 12px rgba(43, 130, 246, 0.5);
    }
    .brand-name {
      font-weight: 600;
      font-size: 1rem;
      letter-spacing: -0.02em;
      color: #fff;
    }
    .topbar-link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
    }
    .topbar-link:hover { color: #e5e7eb; }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
    }
    h1 {
      font-family: 'Libre Baskerville', Georgia, serif;
      margin: 0 0 1.25rem;
      font-size: 1.5rem;
      font-weight: 400;
      color: #fafafa;
    }
    .form-group {
      margin-bottom: 1rem;
    }
    .form-group label {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--muted);
    }
    .form-group label .opt {
      color: #6b7280;
      font-weight: 400;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 8px;
      background: #0a0a0a;
      color: #fff;
      font-size: 0.95rem;
      font-family: inherit;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: var(--primary);
    }
    .form-group textarea {
      min-height: 4.5rem;
      resize: vertical;
    }
    .form-group input::placeholder { color: #6b7280; }
    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
    }
    @media (max-width: 520px) {
      .form-row { grid-template-columns: 1fr; }
    }
    .error {
      color: #f87171;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.7rem 1rem;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
      font-family: inherit;
      transition: background 0.15s;
    }
    button[type="submit"]:hover { background: var(--primary-hover); }
    .back {
      display: inline-block;
      margin-top: 1.5rem;
      color: var(--primary);
      font-size: 0.9rem;
      text-decoration: none;
      font-weight: 500;
    }
    .back:hover { text-decoration: underline; }
    .hint {
      font-size: 0.75rem;
      color: #6b7280;
      margin-top: 0.35rem;
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <a href="/" class="brand" title="Home">
        <div class="brand-mark" aria-hidden="true"><span></span></div>
        <span class="brand-name">AcademiqForge</span>
      </a>
      <a href="/" class="topbar-link">← Home</a>
    </header>

    <div class="card">
      <h1>Create account</h1>
      <% if (error) { %><p class="error"><%= error %></p><% } %>
      <form action="/register" method="post" autocomplete="off" id="reg-form">
        <div class="form-group">
          <label for="title">Title *</label>
          <select id="title" name="title" required>
            <option value="" disabled <%= !form.title ? 'selected' : '' %>>Select…</option>
            <% ['Mr.', 'Mrs.', 'Ms.', 'Miss', 'Mx.', 'Dr.'].forEach(function (t) { %>
              <option value="<%= t %>" <%= form.title === t ? 'selected' : '' %>><%= t %></option>
            <% }); %>
          </select>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First name *</label>
            <input type="text" id="firstName" name="firstName" required placeholder="First name" value="<%= form.firstName || '' %>" />
          </div>
          <div class="form-group">
            <label for="lastName">Last name *</label>
            <input type="text" id="lastName" name="lastName" required placeholder="Last name" value="<%= form.lastName || '' %>" />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email *</label>
          <input type="email" id="email" name="email" required placeholder="you@university.edu" value="<%= form.email || '' %>" autocomplete="email" />
        </div>
        <div class="form-group">
          <label for="password">Password *</label>
          <input type="password" id="password" name="password" required placeholder="At least 8 characters" minlength="8" autocomplete="new-password" />
        </div>
        <div class="form-group">
          <label for="passwordConfirm">Confirm password *</label>
          <input type="password" id="passwordConfirm" name="passwordConfirm" required placeholder="Re-enter password" minlength="8" autocomplete="new-password" />
        </div>

        <div class="form-group">
          <label for="university">University <span class="opt">(optional)</span></label>
          <input type="text" id="university" name="university" list="university-list" placeholder="Type or choose from list" value="<%= form.university || '' %>" />
          <datalist id="university-list">
            <% universities.forEach(function (u) { %>
              <option value="<%= u %>"></option>
            <% }); %>
          </datalist>
          <p class="hint">Pick a school from suggestions or type your institution if it isn’t listed.</p>
        </div>
        <div class="form-group">
          <label for="researchFocus">Research focus <span class="opt">(optional)</span></label>
          <textarea id="researchFocus" name="researchFocus" placeholder="e.g. computational linguistics"><%= form.researchFocus || '' %></textarea>
        </div>
        <div class="form-group">
          <label for="preferredSearchEngine">Preferred search engine <span class="opt">(optional)</span></label>
          <select id="preferredSearchEngine" name="preferredSearchEngine">
            <option value="">—</option>
            <% searchEngines.forEach(function (se) { %>
              <option value="<%= se %>" <%= form.preferredSearchEngine === se ? 'selected' : '' %>><%= se %></option>
            <% }); %>
          </select>
        </div>

        <button type="submit">Create account</button>
      </form>
    </div>
    <a href="/" class="back">← Back to home</a>
  </div>
  <script>
    (function () {
      var form = document.getElementById('reg-form');
      var p1 = document.getElementById('password');
      var p2 = document.getElementById('passwordConfirm');
      form.addEventListener('submit', function (e) {
        if (p1.value !== p2.value) {
          e.preventDefault();
          alert('Password and confirmation must match.');
        }
      });
    })();
  </script>
</body>
</html>
