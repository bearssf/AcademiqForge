<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Subscribe – CollectorAnalytics</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background: #000;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
      color: #fff;
      padding: 2rem;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
    }
    .header a { color: #f0c674; text-decoration: none; }
    .header a:hover { text-decoration: underline; }
    h1 { margin: 0 0 0.5rem; font-size: 1.75rem; }
    .subtitle { color: #888; margin-bottom: 2rem; }
    .plans {
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      max-width: 700px;
      margin: 0 auto;
    }
    .plan {
      flex: 1;
      min-width: 260px;
      background: #111;
      border: 1px solid #333;
      border-radius: 12px;
      padding: 1.5rem;
    }
    .plan h2 { margin: 0 0 0.5rem; font-size: 1.25rem; }
    .plan .price { font-size: 1.75rem; color: #f0c674; margin-bottom: 0.5rem; }
    .plan .period { color: #888; font-size: 0.9rem; margin-bottom: 1rem; }
    .plan form { margin-top: 0.5rem; }
    .plan .pay-method { font-size: 0.8rem; color: #888; margin: 1rem 0 0.25rem; }
    .plan .btn-paypal { background: #003087; }
    .plan .btn-paypal:hover { background: #004c9b; }
    .plan button {
      width: 100%;
      padding: 0.75rem;
      background: #1a5fb4;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      cursor: pointer;
    }
    .plan button:hover { background: #3584e4; }
    .plan.yearly { border-color: #f0c674; }
    .savings { font-size: 0.85rem; color: #7bc275; margin-top: 0.25rem; }
    .error-msg { color: #e06c75; margin-bottom: 1rem; }
  </style>
</head>
<body>
  <div class="header">
    <a href="/">← Home</a>
    <span>Welcome, <%= user.firstName %></span>
  </div>

  <h1>Membership</h1>
  <p class="subtitle">Get access to the members-only area. Cancel anytime.</p>
  <% if (error === 'checkout' || error === 'paypal') { %>
    <p class="error-msg">Payment could not be started. Please try again.</p>
  <% } %>

  <div class="plans">
    <div class="plan">
      <h2>Monthly</h2>
      <div class="price">$0.01</div>
      <div class="period">per month</div>
      <p class="pay-method">Card (Stripe)</p>
      <form action="/create-checkout-session" method="post">
        <input type="hidden" name="plan" value="monthly" />
        <button type="submit">Subscribe with card</button>
      </form>
      <p class="pay-method">PayPal</p>
      <form action="/subscribe/paypal/start" method="get">
        <input type="hidden" name="plan" value="monthly" />
        <button type="submit" class="btn-paypal">Subscribe with PayPal</button>
      </form>
    </div>
    <div class="plan yearly">
      <h2>Yearly</h2>
      <div class="price">$0.02</div>
      <div class="period">per year</div>
      <div class="savings">Save 50% vs monthly</div>
      <p class="pay-method">Card (Stripe)</p>
      <form action="/create-checkout-session" method="post">
        <input type="hidden" name="plan" value="yearly" />
        <button type="submit">Subscribe with card</button>
      </form>
      <p class="pay-method">PayPal</p>
      <form action="/subscribe/paypal/start" method="get">
        <input type="hidden" name="plan" value="yearly" />
        <button type="submit" class="btn-paypal">Subscribe with PayPal</button>
      </form>
    </div>
  </div>
</body>
</html>
