<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('register.verifyPageTitle') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0a;
      --card: #121212;
      --border: rgba(255, 255, 255, 0.08);
      --text: #f5f5f5;
      --muted: #9ca3af;
      --primary: #2b82f6;
      --primary-hover: #4b93f7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse 70% 50% at 20% 20%, rgba(43, 130, 246, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse 50% 40% at 85% 75%, rgba(43, 130, 246, 0.06) 0%, transparent 45%);
      color: var(--text);
      font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 15px;
      line-height: 1.5;
      padding: 0 1.25rem 3rem;
    }
    a { color: inherit; }
    .shell { max-width: 520px; margin: 0 auto; }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 0 1.5rem;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      text-decoration: none;
    }
    .brand-mark {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #141414;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brand-mark span {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 12px rgba(43, 130, 246, 0.5);
    }
    .brand-name { font-weight: 600; font-size: 1rem; letter-spacing: -0.02em; color: #fff; }
    .topbar-link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
    }
    .topbar-link:hover { color: #e5e7eb; }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
    }
    h1 {
      font-family: 'Libre Baskerville', Georgia, serif;
      margin: 0 0 1rem;
      font-size: 1.5rem;
      font-weight: 400;
      color: #fafafa;
    }
    .lead {
      margin: 0 0 1.25rem;
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.5;
    }
    .masked-email {
      font-weight: 600;
      color: #e5e7eb;
      word-break: break-all;
    }
    .form-group { margin-bottom: 1rem; }
    .form-group label {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--muted);
    }
    .form-group input {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 8px;
      background: #0a0a0a;
      color: #fff;
      font-size: 1.15rem;
      letter-spacing: 0.2em;
      text-align: center;
      font-family: ui-monospace, monospace;
    }
    .form-group input:focus {
      outline: none;
      border-color: var(--primary);
    }
    .error {
      color: #f87171;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.7rem 1rem;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
      font-family: inherit;
    }
    button[type="submit"]:hover:not(:disabled) { background: var(--primary-hover); }
    button[type="submit"]:disabled {
      opacity: 0.45;
      cursor: not-allowed;
    }
    .secondary-actions {
      margin-top: 1.25rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .secondary-actions form { margin: 0; }
    .btn-secondary {
      width: 100%;
      padding: 0.55rem 1rem;
      background: transparent;
      color: var(--primary);
      border: 1px solid rgba(43, 130, 246, 0.45);
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
    }
    .btn-secondary:hover:not(:disabled) {
      background: rgba(43, 130, 246, 0.08);
    }
    .btn-secondary:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .resend-hint {
      font-size: 0.78rem;
      color: #6b7280;
      margin-top: 0.35rem;
      min-height: 1.2em;
    }
    .links-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
      font-size: 0.88rem;
    }
    .links-row a { color: var(--primary); text-decoration: none; font-weight: 500; }
    .links-row a:hover { text-decoration: underline; }
    .back {
      display: inline-block;
      margin-top: 1.25rem;
      color: var(--primary);
      font-size: 0.9rem;
      text-decoration: none;
      font-weight: 500;
    }
    .back:hover { text-decoration: underline; }
    .visually-hidden {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <a href="/" class="brand" title="Home">
        <div class="brand-mark" aria-hidden="true"><span></span></div>
        <span class="brand-name">AcademiqForge</span>
      </a>
      <a href="/" class="topbar-link"><%= t('register.topLinkHome') %></a>
    </header>

    <div class="card">
      <h1><%= t('register.verifyTitle') %></h1>
      <p class="lead"><%= t('register.verifyInstructions') %></p>
      <p class="lead"><span class="masked-email" id="masked-email"><%= typeof maskedEmail !== 'undefined' ? maskedEmail : '' %></span></p>
      <% if (error) { %><p class="error" role="alert"><%= error %></p><% } %>
      <form action="/register/verify" method="post" autocomplete="off">
        <div class="form-group">
          <label for="verify-code"><%= t('register.verifyCodeLabel') %></label>
          <input type="text" id="verify-code" name="code" inputmode="numeric" pattern="[0-9]*" maxlength="6" required autocomplete="one-time-code" aria-describedby="code-hint" />
          <span id="code-hint" class="visually-hidden"><%= t('register.verifyCodeHint') %></span>
        </div>
        <button type="submit"><%= t('register.verifySubmit') %></button>
      </form>
      <div class="secondary-actions">
        <form action="/register/resend" method="post">
          <button type="submit" class="btn-secondary" id="resend-btn" <%= typeof canResendNow !== 'undefined' && canResendNow ? '' : 'disabled' %>><%= t('register.verifyResend') %></button>
          <p class="resend-hint" id="resend-hint" <%= typeof canResendNow !== 'undefined' && canResendNow ? 'hidden' : '' %>></p>
        </form>
        <div class="links-row">
          <a href="/register/change-email"><%= t('register.verifyChangeEmail') %></a>
        </div>
      </div>
      <a href="/register" class="back"><%= t('register.verifyBackRegister') %></a>
    </div>
  </div>
  <script>
    (function () {
      var btn = document.getElementById('resend-btn');
      var hint = document.getElementById('resend-hint');
      var iso = <%= JSON.stringify(typeof resendAtIso !== 'undefined' ? resendAtIso : '') %>;
      var canNow = <%= typeof canResendNow !== 'undefined' && canResendNow ? 'true' : 'false' %>;
      var msg = <%= JSON.stringify(t('register.verifyResendCountdown')) %>;
      if (!btn || !hint || canNow || !iso) return;
      var target = Date.parse(iso);
      if (Number.isNaN(target)) return;
      function tick() {
        var left = Math.max(0, Math.ceil((target - Date.now()) / 1000));
        if (left <= 0) {
          btn.disabled = false;
          hint.textContent = '';
          hint.hidden = true;
          return;
        }
        var m = Math.floor(left / 60);
        var s = left % 60;
        hint.textContent = msg.replace('{m}', String(m)).replace('{s}', s < 10 ? '0' + s : String(s));
        hint.hidden = false;
        setTimeout(tick, 1000);
      }
      tick();
    })();
  </script>
</body>
</html>
