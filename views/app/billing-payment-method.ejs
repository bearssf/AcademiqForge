<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <% var title = t('billing.paymentMethodTitle'); %>
  <%- include('../partials/app-head') %>
</head>
<body class="app-body app-body--account-page app-body--billing-payment-method">
  <div class="app-grid app-grid--account">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'account', projects: projects, currentProjectId: currentProjectId, workspaceSlug: '', appAccess: appAccess }) %>
    <main class="app-canvas">
      <h1><%= t('billing.paymentMethodTitle') %></h1>
      <p class="sub billing-pm-lead"><%= t('billing.paymentMethodLead') %></p>

      <div class="app-placeholder account-block billing-subscribe-card">
        <p class="account-meta" style="margin-top:0"><%= t('billing.paymentMethodBlurb') %></p>
        <form id="billing-pm-form" class="billing-subscribe-form">
          <div id="billing-pm-payment"></div>
          <p class="account-meta billing-pm-legal">
            <%= t('billing.paymentMethodLegal') %>
          </p>
          <p id="billing-pm-error" class="billing-subscribe-error" hidden></p>
          <button type="submit" id="billing-pm-submit" class="app-btn-primary billing-subscribe-submit" disabled>
            <%= t('billing.savePayment') %>
          </button>
        </form>
        <p class="account-meta"><a href="/app/account" class="app-link-cta"><%= t('billing.backAccount') %></a></p>
      </div>
    </main>
  </div>
  <script src="https://js.stripe.com/v3/"></script>
  <script>
    window.__BILLING_PM__ = {
      publishableKey: <%- JSON.stringify(stripePublishableKey) %>,
      stripeLocale: <%- JSON.stringify(typeof stripeLocale !== 'undefined' ? stripeLocale : 'en') %>
    };
  </script>
  <script src="/js/billing-payment-method.js" defer></script>
</body>
</html>
