<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <% var title = t('billing.subscribeTitle'); %>
  <%- include('../partials/app-head') %>
</head>
<body class="app-body app-body--account-page">
  <div class="app-grid app-grid--account">
    <%- include('../partials/app-sidebar', { user: user, navActive: 'account', projects: projects, currentProjectId: currentProjectId, workspaceSlug: '', appAccess: appAccess }) %>
    <main class="app-canvas">
      <h1><%= t('billing.subscribeTitle') %></h1>
      <p class="sub"><%= t('billing.subscribeSub', { interval: intervalLabel }) %></p>

      <div class="app-placeholder account-block billing-subscribe-card">
        <p class="account-meta" style="margin-top:0"><%= t('billing.cardBlurb') %></p>
        <div class="billing-promo-row" id="billing-promo-row">
          <label class="billing-promo-label" for="billing-promo-input"><%= t('billing.promoLabel') %></label>
          <div class="billing-promo-controls">
            <input type="text" id="billing-promo-input" class="billing-promo-input" placeholder="<%= t('billing.promoOptional') %>" autocomplete="off" />
            <button type="button" id="billing-promo-apply" class="app-btn-secondary billing-promo-apply"><%= t('billing.promoApply') %></button>
          </div>
          <p id="billing-promo-hint" class="billing-promo-hint" hidden></p>
        </div>
        <form id="billing-subscribe-form" class="billing-subscribe-form">
          <div id="billing-subscribe-payment"></div>
          <p id="billing-subscribe-error" class="billing-subscribe-error" hidden></p>
          <button type="submit" id="billing-subscribe-submit" class="app-btn-primary billing-subscribe-submit" disabled>
            <%= t('billing.paySubscribe') %>
          </button>
        </form>
        <p class="account-meta"><a href="/app/account" class="app-link-cta"><%= t('billing.backAccount') %></a></p>
      </div>
    </main>
  </div>
  <script src="https://js.stripe.com/v3/"></script>
  <script>
    window.__BILLING_SUBSCRIBE__ = {
      publishableKey: <%- JSON.stringify(stripePublishableKey) %>,
      interval: <%- JSON.stringify(billingInterval) %>,
      priceMode: <%- JSON.stringify(billingPriceMode) %>,
      promoPrefill: <%- JSON.stringify(typeof promoPrefill !== 'undefined' ? promoPrefill : '') %>,
      stripeLocale: <%- JSON.stringify(typeof stripeLocale !== 'undefined' ? stripeLocale : 'en') %>
    };
  </script>
  <script src="/js/billing-subscribe.js" defer></script>
</body>
</html>
