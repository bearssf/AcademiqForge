<!DOCTYPE html>
<html lang="<%= typeof htmlLang !== 'undefined' ? htmlLang : 'en' %>" dir="<%= typeof textDir !== 'undefined' ? textDir : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t('register.changeEmailPageTitle') %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0a0a0a;
      --card: #121212;
      --border: rgba(255, 255, 255, 0.08);
      --text: #f5f5f5;
      --muted: #9ca3af;
      --primary: #2b82f6;
      --primary-hover: #4b93f7;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      background-color: var(--bg);
      background-image:
        radial-gradient(ellipse 70% 50% at 20% 20%, rgba(43, 130, 246, 0.1) 0%, transparent 50%),
        radial-gradient(ellipse 50% 40% at 85% 75%, rgba(43, 130, 246, 0.06) 0%, transparent 45%);
      color: var(--text);
      font-family: Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      font-size: 15px;
      line-height: 1.5;
      padding: 0 1.25rem 3rem;
    }
    a { color: inherit; }
    .shell { max-width: 520px; margin: 0 auto; }
    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1.25rem 0 1.5rem;
    }
    .brand {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      text-decoration: none;
    }
    .brand-mark {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      background: #141414;
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .brand-mark span {
      width: 14px;
      height: 14px;
      border-radius: 50%;
      background: var(--primary);
      box-shadow: 0 0 12px rgba(43, 130, 246, 0.5);
    }
    .brand-name { font-weight: 600; font-size: 1rem; letter-spacing: -0.02em; color: #fff; }
    .topbar-link {
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--muted);
      text-decoration: none;
    }
    .topbar-link:hover { color: #e5e7eb; }
    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 2rem;
    }
    h1 {
      font-family: 'Libre Baskerville', Georgia, serif;
      margin: 0 0 1rem;
      font-size: 1.5rem;
      font-weight: 400;
      color: #fafafa;
    }
    .lead {
      margin: 0 0 1.25rem;
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.5;
    }
    .form-group { margin-bottom: 1rem; }
    .form-group label {
      display: block;
      margin-bottom: 0.35rem;
      font-size: 0.8rem;
      font-weight: 500;
      color: var(--muted);
    }
    .form-group input {
      width: 100%;
      padding: 0.6rem 0.75rem;
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 8px;
      background: #0a0a0a;
      color: #fff;
      font-size: 0.95rem;
      font-family: inherit;
    }
    .form-group input:focus {
      outline: none;
      border-color: var(--primary);
    }
    .error {
      color: #f87171;
      font-size: 0.9rem;
      margin-bottom: 1rem;
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.7rem 1rem;
      background: var(--primary);
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 0.5rem;
      font-family: inherit;
    }
    button[type="submit"]:hover { background: var(--primary-hover); }
    .back {
      display: inline-block;
      margin-top: 1.5rem;
      color: var(--primary);
      font-size: 0.9rem;
      text-decoration: none;
      font-weight: 500;
    }
    .back:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="shell">
    <header class="topbar">
      <a href="/" class="brand" title="Home">
        <div class="brand-mark" aria-hidden="true"><span></span></div>
        <span class="brand-name">AcademiqForge</span>
      </a>
      <a href="/" class="topbar-link"><%= t('register.topLinkHome') %></a>
    </header>

    <div class="card">
      <h1><%= t('register.changeEmailTitle') %></h1>
      <p class="lead"><%= t('register.changeEmailLead') %></p>
      <% if (error) { %><p class="error" role="alert"><%= error %></p><% } %>
      <form action="/register/change-email" method="post" autocomplete="off">
        <div class="form-group">
          <label for="ce-email"><%= t('auth.email') %></label>
          <input type="email" id="ce-email" name="email" required autocomplete="email" value="<%= typeof email !== 'undefined' ? email : '' %>" />
        </div>
        <button type="submit"><%= t('register.changeEmailSubmit') %></button>
      </form>
      <a href="/register/verify" class="back"><%= t('register.changeEmailBackVerify') %></a>
    </div>
  </div>
</body>
</html>
